# Firebase Web Push (FCM) — Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
VITE_FIREBASE_VAPID_KEY=your_web_push_vapid_key_here

# Cloudinary unsigned uploads for product images
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name_here
VITE_CLOUDINARY_UPLOAD_FOLDER=nitto-bazar/products

# Android APK native FCM — only after placing google-services.json in android/app/ (from Firebase Console, package com.nittobazar.app)
# VITE_NATIVE_PUSH_ENABLED=true
